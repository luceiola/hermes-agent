# -----------------------------
# Zhipu Homework Agent
# -----------------------------
# Required for Zhipu provider
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/v1
ZHIPU_CORRECTION_AGENT_ID=intelligent_education_correction_agent
ZHIPU_POLLING_AGENT_ID=intelligent_education_correction_polling
ZHIPU_ANALYSIS_AGENT_ID=intelligent_education_correction_analysis

# -----------------------------
# Baidu OCR Correct Edu
# -----------------------------
# Option A: set API key + secret key (auto fetch token)
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=

# Option B: direct token (optional, overrides OAuth fetch)
BAIDU_OCR_ACCESS_TOKEN=

BAIDU_CORRECT_EDU_BASE_URL=https://aip.baidubce.com/rest/2.0/ocr/v1
BAIDU_OAUTH_URL=https://aip.baidubce.com/oauth/2.0/token

# ===== Profile routing =====
HERMES_PRIMARY_PLATFORM=weixin

# ===== Weixin credentials (Official iLink Bot API) =====
WEIXIN_ACCOUNT_ID=
WEIXIN_TOKEN=
WEIXIN_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c

# Access control
WEIXIN_DM_POLICY=open
WEIXIN_GROUP_POLICY=disabled
WEIXIN_ALLOWED_USERS=
WEIXIN_GROUP_ALLOWED_USERS=
WEIXIN_ALLOW_ALL_USERS=false

# Optional home channel for cron/notification delivery
WEIXIN_HOME_CHANNEL=
WEIXIN_HOME_CHANNEL_NAME=Mei

# ===== Model provider =====
API_KEY=
BASE_URL=
MODEL=qwen3.6-plus

# ===== Homework correction APIs (optional, for tools/homework_eval) =====
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/v1
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_ACCESS_TOKEN=

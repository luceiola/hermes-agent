# ===== Profile routing =====
HERMES_PRIMARY_PLATFORM=feishu

# ===== Feishu bot credentials =====
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket

# Optional (recommended for webhook mode)
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# Access control
FEISHU_ALLOWED_USERS=
FEISHU_GROUP_POLICY=open
FEISHU_HOME_CHANNEL=

# Webhook mode isolation defaults (ignored in websocket mode)
FEISHU_WEBHOOK_HOST=127.0.0.1
FEISHU_WEBHOOK_PORT=8867
FEISHU_WEBHOOK_PATH=/feishu/orchestrator/webhook

# ===== Main model provider =====
API_KEY=
BASE_URL=
MODEL=qwen3.6-plus

# ===== Video pipeline provider (optional) =====
SEEDANCE_PROVIDER=seedance
VOLCENGINE_API_KEY=
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com
SEEDANCE_MODEL=doubao-seedance-2-0-260128
SEEDANCE_CREATE_PATH=/api/v3/contents/generations/tasks
SEEDANCE_STATUS_PATH_TEMPLATE=/api/v3/contents/generations/tasks/{task_id}
SEEDANCE_TIMEOUT_SECONDS=60

# Optional aliases for Ark APIs
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_MODEL_VIDEO_UNDERSTAND=doubao-seed-2-0-mini-260215

# ===== Local toolchain path bindings (optional) =====
VIDEO_AGENT_REPO=/Users/lucas/Documents/video-agent
VIDEO_STRATEGIST_REPO=/Users/lucas/Documents/video-strategist
VIDEO_TASK_STORE_PATH=$HOME/.hermes/profiles/orchestrator/platforms/video_director/tasks.json
VIDEO_STRATEGY_STORE_PATH=$HOME/.hermes/profiles/orchestrator/platforms/video_strategist/sessions.json

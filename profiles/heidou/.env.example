# ===== Profile routing =====
HERMES_PRIMARY_PLATFORM=qqbot

# ===== QQ Bot credentials (Official QQ Bot API v2) =====
QQ_APP_ID=
QQ_CLIENT_SECRET=

# Access control
QQ_ALLOWED_USERS=
QQ_GROUP_ALLOWED_USERS=
QQ_ALLOW_ALL_USERS=false

# Optional home channel for cron/notification delivery
QQ_HOME_CHANNEL=
QQ_HOME_CHANNEL_NAME=Heidou

# ===== Model provider =====
API_KEY=
BASE_URL=
MODEL=qwen3.6-plus

# ===== Homework correction APIs (optional, for tools/homework_eval) =====
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/v1
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_ACCESS_TOKEN=

# ===== Vocab extractor (optional independent call, tools/vocab_extractor) =====
# Leave empty to fallback to main API_KEY/BASE_URL/MODEL settings.
VOCAB_API_KEY=
VOCAB_BASE_URL=
VOCAB_MODEL=qwen3.6-plus

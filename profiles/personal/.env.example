# ===== Profile routing =====
HERMES_PRIMARY_PLATFORM=feishu

# ===== Feishu bot credentials (personal bot) =====
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_DOMAIN=feishu
FEISHU_CONNECTION_MODE=websocket

# Optional (recommended for webhook mode)
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# Access control
FEISHU_ALLOWED_USERS=
FEISHU_GROUP_POLICY=allowlist
FEISHU_HOME_CHANNEL=

# Webhook mode isolation defaults (ignored in websocket mode)
FEISHU_WEBHOOK_HOST=127.0.0.1
FEISHU_WEBHOOK_PORT=8865
FEISHU_WEBHOOK_PATH=/feishu/personal/webhook

# ===== Model provider =====
OPENAI_API_KEY=

# ===== Homework correction APIs (optional, for tools/homework_eval) =====
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/v1
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
BAIDU_OCR_ACCESS_TOKEN=
